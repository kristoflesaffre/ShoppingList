# Kopieer naar `.env.local` en vul aan (zie README).
# Admin-token: Instant dashboard → je app → Settings / Admin.

INSTANT_APP_ADMIN_TOKEN=
# Komma-gescheiden e-mailadressen die het adminoverzicht mogen openen.
ADMIN_EMAILS=lesaffrekristof@gmail.com
# Optioneel: komma-gescheiden Instant user ids die het adminoverzicht mogen openen.
ADMIN_INSTANT_USER_IDS=
# Optioneel: nieuwe user-afbeeldingen in Vercel Blob opslaan.
# Zonder token valt de app terug op legacy data-URLs in InstantDB.
BLOB_READ_WRITE_TOKEN=
# Optioneel:
# NEXT_PUBLIC_INSTANT_APP_ID=
